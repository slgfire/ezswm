{
  "name": "ezswm",
  "version": "0.30.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "pnpm --filter ezswm-docs dev",
    "docs:build": "pnpm --filter ezswm-docs build",
    "docs:preview": "pnpm --filter ezswm-docs preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nuxt/ui": "4.9.0",
    "@nuxtjs/i18n": "10.4.0",
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/client": "7.8.0",
    "@types/qrcode": "1.5.6",
    "bcryptjs": "3.0.3",
    "better-sqlite3": "12.11.1",
    "jsonwebtoken": "9.0.3",
    "marked": "^18.0.5",
    "nanoid": "5.1.11",
    "nuxt": "4.4.8",
    "prisma": "7.8.0",
    "qrcode": "1.5.4",
    "tailwindcss": "4.3.1",
    "v-network-graph": "0.9.22",
    "vuedraggable": "4.1.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@iconify-json/tabler": "^1.2.35",
    "@nuxt/eslint": "1.16.0",
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "3.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^25.9.3",
    "eslint": "10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  }
}
